[global]
filename=/dev/nvme0n1
size=4G
rw=randread
bs=4k
ioengine=libaio
iodepth=32
numjobs=16
direct=1
runtime=60
ramp_time=10
time_based=1
group_reporting=1
percentile_list=50:90:95:99:99.9:99.99
write_iops_log=/root/randread_iops
write_lat_log=/root/randread_lat
log_avg_msec=1000

[randread-4k-aio]
